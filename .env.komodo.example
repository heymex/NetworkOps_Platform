# Core auth and security
JWT_SECRET=replace-with-64-char-random-secret
JWT_EXPIRATION_HOURS=24
MFA_ENABLED=true
MFA_ENCRYPTION_KEY=

# Runtime mode
DEMO_MODE=false
FLASK_ENV=production
DASHBOARD_ORIGIN=http://localhost:3000

# Infrastructure passwords (set in Komodo secrets)
POSTGRES_PASSWORD=replace-with-strong-postgres-password
REDIS_PASSWORD=replace-with-strong-redis-password

# Device credentials (required for non-demo mode)
DEVICE_USERNAME=admin
DEVICE_PASSWORD=replace-with-device-password

# Optional AI/RAG
ANTHROPIC_API_KEY=

# Optional integrations
USE_NETBOX=false
NETBOX_URL=http://localhost:8000
NETBOX_API_TOKEN=

# Optional observability and enterprise settings
SIEM_ENABLED=false
ENABLE_HIERARCHICAL_VIEW=false
